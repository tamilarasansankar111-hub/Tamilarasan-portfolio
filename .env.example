# Copy this file to .env and fill in your real values.
# Never commit the real .env file to version control.

# Flask
SECRET_KEY=replace-with-a-long-random-string
FLASK_ENV=development

# Supabase — Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Admin login (the actual password is set in Supabase Auth > Users, not here)
ADMIN_EMAIL=tamilarasansankar111@gmail.com
